{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"$HOME/.claude/hooks/session_summarize.py\" start"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"$HOME/.claude/hooks/prompt_timestamp.py\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"$HOME/.claude/hooks/prompt_questions.py\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"$HOME/.claude/hooks/prompt_pr_scope.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"$HOME/.claude/hooks/pre_tool_config_guard.py\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"$HOME/.claude/hooks/pre_tool_quality.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"$HOME/.claude/hooks/post_tool_lint.py\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"$HOME/.claude/hooks/post_tool_bypass_warn.py\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"$HOME/.claude/hooks/post_tool_quality.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"$HOME/.claude/hooks/stop_quality.py\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"$HOME/.claude/hooks/session_summarize.py\" end"
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true
}
